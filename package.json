{
  "name": "jode",
  "version": "0.0.0",
  "private": true,
  "description": "One home for every AI coding agent — running in the cloud, editable on your laptop.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node tools/dev.mjs",
    "dev:desktop": "npm run dev --workspace @jode/desktop",
    "build": "npm run build --workspace @jode/desktop",
    "cc:build-payload": "npm run build:payload --workspace @jode/claude-code",
    "cc:gen": "npm run gen --workspace @jode/claude-code",
    "cc:deploy": "npm run deploy --workspace @jode/claude-code",
    "cc:dry-run": "npm run dry-run --workspace @jode/claude-code",
    "oc:deploy": "npm run deploy --workspace @jode/opencode",
    "oc:dry-run": "npm run dry-run --workspace @jode/opencode",
    "cx:build-payload": "npm run build:payload --workspace @jode/codex",
    "cx:gen": "npm run gen --workspace @jode/codex",
    "cx:deploy": "npm run deploy --workspace @jode/codex",
    "cx:dry-run": "npm run dry-run --workspace @jode/codex",
    "deploy": "npm run cc:deploy && npm run oc:deploy && npm run cx:deploy",
    "dry-run": "npm run cc:dry-run && npm run oc:dry-run && npm run cx:dry-run"
  }
}
