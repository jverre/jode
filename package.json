{
  "name": "jode",
  "version": "0.0.0",
  "private": true,
  "description": "One home for every AI coding agent — running in the cloud, editable on your laptop.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node tools/dev.mjs",
    "build": "npm run build --workspace @jode/desktop",
    "deploy": "node tools/cloud-stack.mjs deploy",
    "dry-run": "node tools/cloud-stack.mjs dry-run",
    "logs:selector": "npm run tail --workspace @jode/selector",
    "logs:claude": "npm run tail --workspace @jode/claude-code",
    "logs:codex": "npm run tail --workspace @jode/codex",
    "logs:opencode": "npm run tail --workspace @jode/opencode"
  }
}
