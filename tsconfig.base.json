{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@jode/agents": ["packages/agents/src/index.ts"],
      "@jode/auth": ["packages/auth/src/index.ts"],
      "@jode/edge": ["packages/edge/src/index.ts"],
      "@jode/shell": ["packages/shell/src/index.ts"]
    }
  }
}
