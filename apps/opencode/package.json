{
  "name": "@jode/opencode",
  "private": true,
  "type": "module",
  "description": "jode remote environment — Worker + Durable Object + Container serving the OpenCode web UI.",
  "scripts": {
    "deploy": "node ../../tools/sync-runtime.mjs && wrangler deploy",
