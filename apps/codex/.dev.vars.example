# Local dev secrets for `wrangler dev`. Copy to `.dev.vars` (gitignored) and fill in.
# In production these are set via `wrangler secret put` / the [vars] block in wrangler.toml.

# Worker→container shared secret (defense-in-depth on the private DO binding).
# Generate one, e.g.: openssl rand -hex 32
BRIDGE_KEY="dev-bridge-key"

# Local dev: skip Cloudflare Access verification so the desktop webview can load
# the agent under `wrangler dev` (you can't mint a real Access JWT locally). This
# is read ONLY here — never put it in wrangler.toml [vars] / production.
ACCESS_DEV_BYPASS="true"

# Cloudflare Access — only used when ACCESS_DEV_BYPASS is not "true".
ACCESS_TEAM_DOMAIN="https://YOUR-TEAM.cloudflareaccess.com"
ACCESS_AUD="REPLACE_WITH_ACCESS_APPLICATION_AUD_TAG"
ALLOWED_EMAIL="jacques@comet.com"

# The SHARED jode filesystem (one R2 bucket FUSE-mounted at /workspace by every
# tool; see wrangler.toml + scripts/mount-workspace.sh). In production these are
# secrets:
#   wrangler secret put R2_ENDPOINT          # https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   wrangler secret put R2_ACCESS_KEY_ID     # R2 API token (Object Read & Write)
#   wrangler secret put R2_SECRET_ACCESS_KEY
# NOTE: under `wrangler dev` the mount CANNOT work (no /dev/fuse / SYS_ADMIN in
# local containers) — /workspace falls back to local-ephemeral. For the real
# shared FS locally, use the standalone docker flow in scripts/dev-proxy.mjs
# (works against real R2, or MinIO with R2_PROVIDER=Minio).
#R2_ENDPOINT=""
#R2_ACCESS_KEY_ID=""
#R2_SECRET_ACCESS_KEY=""
